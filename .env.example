# Root env template for reference.
# This monorepo reads env values from service-specific files:
# - smart-contracts/.env
# - backend/.env
# - frontend/.env

# Smart contracts (copy to smart-contracts/.env)
SEPOLIA_RPC_URL=https://rpc.sepolia.org
DEPLOYER_PRIVATE_KEY=YOUR_PRIVATE_KEY_WITHOUT_0x

# Backend (copy to backend/.env)
PINATA_API_KEY=YOUR_PINATA_API_KEY
PINATA_API_SECRET=YOUR_PINATA_API_SECRET
CORS_ALLOWED_ORIGINS=http://localhost:5173
MAX_UPLOAD_BYTES=5242880
MAX_UPLOADS_PER_MINUTE=20
PORT=3000

# Frontend (copy to frontend/.env)
VITE_CONTRACT_ADDRESS=0xYOUR_DEPLOYED_CONTRACT_ADDRESS
VITE_API_BASE_URL=http://localhost:3000
VITE_REQUIRED_CHAIN_ID=31337
